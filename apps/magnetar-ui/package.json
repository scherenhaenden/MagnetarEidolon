{
  "name": "@magnetar/magnetar-ui",
  "version": "0.2.0",
  "private": false,
  "description": "MagnetarEidolon TypeScript UI workspace with a shared CLI/runtime proof of concept.",
  "type": "module",
  "scripts": {
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "npm run build:web && npm run build:cli",
    "build:web": "ng build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "typecheck": "npm run typecheck:web && npm run typecheck:cli && npm run typecheck:test",
    "typecheck:web": "ngc -p tsconfig.app.json --noEmit",
    "typecheck:cli": "tsc -p tsconfig.cli.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "cli:dev": "node --import tsx src/cli/magnetar-cli.ts",
    "cli": "node dist/cli/magnetar-cli.js",
    "web:open": "ng serve --proxy-config proxy.conf.json --open"
  },
  "bin": {
    "magnetar-cli": "dist/cli/magnetar-cli.js"
  },
  "dependencies": {
    "@angular/router": "21.2.1",
    "@magnetar/magnetar-sdk": "file:../../packages/magnetar-sdk",
    "rxjs": "^7.8.1",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
