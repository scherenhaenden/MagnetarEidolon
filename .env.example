# PyCharm/IDE runtime environment
# Keep both roots so imports work for the src-layout package and the UI app module.
PYTHONPATH=src:magnetar_voice_ui

# MagnetarEidolon backend provider configuration
# Copy these into a real `.env` or local runtime environment. Do not commit real keys.
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_DEFAULT_MODEL=local-model

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4.1-mini
OPENROUTER_API_KEY=
# Optional attribution headers for OpenRouter requests.
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=MagnetarEidolon Dev
