{
  "name": "@magnetar/magnetar-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript runtime contract for MagnetarEidolon UI and CLI clients.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "exports": {
    "./agent": {
      "types": "./dist/agent.d.ts",
      "default": "./dist/agent.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces.d.ts",
      "default": "./dist/interfaces.js"
    },
    "./models": {
      "types": "./dist/models.d.ts",
      "default": "./dist/models.js"
    },
    "./providers/lm-studio": {
      "types": "./dist/providers/lm-studio.d.ts",
      "default": "./dist/providers/lm-studio.js"
    },
    "./tools/node-filesystem": {
      "types": "./dist/tools/node-filesystem.d.ts",
      "default": "./dist/tools/node-filesystem.js"
    },
    "./tools/web-filesystem": {
      "types": "./dist/tools/web-filesystem.d.ts",
      "default": "./dist/tools/web-filesystem.js"
    }
  },
  "dependencies": {
    "@types/node": "^22.10.2",
    "rxjs": "^7.8.1",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  }
}
